{
  "name": "nodepad-obsidian-plugin",
  "version": "0.1.0",
  "description": "Obsidian plugin for Nodepad",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"node esbuild.config.mjs\" \"npx @tailwindcss/cli -i src/styles.css -o styles.css --watch\"",
    "build": "tsc --noEmit -p tsconfig.json && node esbuild.config.mjs production && npx @tailwindcss/cli -i src/styles.css -o styles.css"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "builtin-modules": "^4.0.0",
    "concurrently": "^9.0.0",
    "esbuild": "0.21.5",
    "obsidian": "latest",
    "tailwindcss": "^4.0.0",
    "typescript": "5.7.3"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19"
  }
}
